# Weather ingest (Điện Biên) — Open-Meteo không cần key, chỉ cấu hình timeout.
WEATHER_FETCH_TIMEOUT_MS=8000
# OpenWeatherMap — nguồn dự phòng/đối chiếu khi Open-Meteo lỗi/timeout.
# Lấy key tại: home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=

# NCHMF — lớp đối chiếu/validation với dự báo chính thức nhà nước (chỉ áp
# dụng cho địa điểm 'dbp', xem nchmf-reference.ts). Không cần key.
NCHMF_FETCH_TIMEOUT_MS=8000

# AI Engine (FastAPI, xem ai_engine/) — dùng cho POST /assess-risk.
AI_ENGINE_BASE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT_MS=8000

# REST API
API_PORT=3000

# CORS — domain PHỤ được phép gọi API ngoài https://forestgump.pages.dev (đã
# cho phép cứng trong backend/src/api.ts). Phân tách bằng dấu phẩy nếu nhiều.
CORS_ORIGIN=
