# SaliGuard - Biến môi trường cho Satellite Engine (module ảnh vệ tinh, FastAPI riêng)
# Copy thành `.env` trong thư mục này nếu cần override giá trị mặc định (config.py).
# KHÔNG commit file `.env`.

# Kích thước tile khi cắt ảnh GeoTIFF để train/infer (pixel).
SATELLITE_TILE_SIZE=256
# Stride khi cắt tile lúc train (pixel).
SATELLITE_TRAIN_STRIDE=256
# Stride khi cắt tile lúc infer (nhỏ hơn train stride -> tile chồng lấn, mượt hơn ở biên).
SATELLITE_INFER_STRIDE=192

# Thư mục gốc chứa dữ liệu vệ tinh (raw/tiles/splits).
SATELLITE_DATA_ROOT=../data/satellite

# Backbone HuggingFace dùng cho Segformer.
SATELLITE_MODEL_NAME=nvidia/mit-b0

# Đường dẫn checkpoint model đã train. Trong Docker, trỏ vào path được mount
# qua volume (vd: /models/segformer_b0_best.pt), xem docker-compose.prod.yml.
SATELLITE_CHECKPOINT=models/segformer_b0_best.pt

# Ép device chạy inference: mps (Apple Silicon, mặc định nếu có sẵn), cpu, cuda.
# Để trống -> tự động chọn mps nếu máy hỗ trợ, ngược lại dùng cpu.
# Trong container Linux (không có MPS) nên set cpu tường minh.
SATELLITE_DEVICE=
