# Forestgump - Biến môi trường production
# Copy file này thành `.env` (cùng cấp docker-compose.*.yml) rồi điền giá trị thật.
# KHÔNG commit file `.env` (đã có trong .gitignore).
# Dùng chung cho cả 2 cách deploy backend — chỉ điền phần tương ứng cách bạn chọn.

# --- CORS: domain Cloudflare Pages của dashboard (phân tách bằng dấu phẩy nếu nhiều domain) ---
CORS_ORIGIN=https://forestgump.pages.dev

# --- [Cách A: VPS + Caddy, dùng với docker-compose.prod.yml] ---
# Domain public trỏ tới VPS cho REST API (Caddy tự xin HTTPS Let's Encrypt).
API_DOMAIN=api.forestgump.example.com

# --- [Cách B: tự host tại nhà + Cloudflare Tunnel, dùng với docker-compose.selfhost.yml] ---
# Token lấy từ Cloudflare Zero Trust > Networks > Tunnels > Create a tunnel
# > Cloudflared > phần "Install and run connector" (copy đoạn token trong lệnh
# `cloudflared service install <TOKEN>`). Xem DEPLOY.md phần E.
CLOUDFLARE_TUNNEL_TOKEN=

# --- OpenWeatherMap — nguồn dự phòng/đối chiếu khi Open-Meteo lỗi/timeout ---
# Lấy key tại: home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=
