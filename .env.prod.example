# SaliGuard - Biến môi trường production (dùng với docker-compose.prod.yml)
# Copy file này thành `.env` (cùng cấp docker-compose.prod.yml) rồi điền giá trị thật.
# KHÔNG commit file `.env` (đã có trong .gitignore).

# --- PostgreSQL / TimescaleDB ---
DB_USER=postgres
DB_PASSWORD=changeme_mat_khau_manh
DB_NAME=saliguard

# --- Trạm gắn phần cứng thật (các trạm khác trả dữ liệu mock) ---
REAL_STATION_ID=ST001

# --- Satellite Engine — URL nội bộ được set cứng trong docker-compose.prod.yml
# (http://satellite_engine:8010, nội bộ docker network), không cần khai báo
# ở đây. Chỉ timeout là chỉnh được qua biến dưới đây (mặc định 30000ms nếu bỏ trống). ---
SATELLITE_ENGINE_TIMEOUT_MS=30000

# --- CORS: domain Cloudflare Pages của dashboard (phân tách bằng dấu phẩy nếu nhiều domain) ---
CORS_ORIGIN=https://saliguard.pages.dev

# --- Caddy: domain public trỏ tới VPS cho REST API (Caddy tự xin HTTPS Let's Encrypt) ---
API_DOMAIN=api.saliguard.example.com

# --- Chatbot (Gemini) ---
GEMINI_API_KEY=
CHAT_MODEL=gemini-3.1-flash-lite

# --- Gmail SMTP — dùng App Password (không phải mật khẩu Gmail thường) ---
# Tạo tại: myaccount.google.com -> Security -> 2-Step Verification -> App passwords
GMAIL_USER=saliguardai@gmail.com
GMAIL_APP_PASSWORD=

# --- Stringee — gọi điện thoại + SMS cảnh báo khẩn cấp (mức đỏ, EC > 4 g/L) ---
# Lấy SID/Secret tại: developer.stringee.com -> dự án của bạn -> Project keys
STRINGEE_SID=
STRINGEE_SECRET=
STRINGEE_FROM_NUMBER=
ALERT_TO_NUMBER=
# URL public trỏ tới backend này (dùng làm answer_url cho Stringee)
PUBLIC_WEBHOOK_URL=https://api.saliguard.example.com
